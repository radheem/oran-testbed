# ─────────────────────────────────────────────────────────────────────────────
# cudu-deploy — global deployment settings
#
# Sourced by scripts/manage.sh and used as the compose env file. Per-component
# .env files live next to their compose (monitoring/.env, ric/.env, ue/multi_ue/.env).
# ─────────────────────────────────────────────────────────────────────────────

# Which gNB to start with `manage.sh start gnb`: zmq | uhd
DEPLOY_TYPE=zmq

# ── Images ───────────────────────────────────────────────────────────────────
# gNB: rptestbed/gnb:20260610-dpdk is built at x86-64-v4 and runs on Cascade Lake
# (srsRAN build -> SINGULAR addr/bind_addr in configs/gnb_zmq.yml).
# NOTE: rptestbed/docker-gnb:11062026 (OCUDU, plural addrs schema) is built for a
# higher CPU ISA and SIGILLs (exit 132) on this host once the PHY runs; to use it,
# rebuild with MARCH=x86-64-v4 and switch the gNB configs back to addrs/bind_addrs.
GNB_IMAGE=rptestbed/gnb:20260610-dpdk
OPEN5GS_IMAGE=rptestbed/docker-5gc:11062026
OPEN5GS_VERSION=v2.7.6
OPEN5GS_OS_VERSION=22.04

# ── Networks (created by scripts/net_manage.sh as external bridges) ───────────
# n2  : NGAP (SCTP) + NG-U GTP-U between 5GC and gNB(s)
# n3  : ZMQ RF transport wire between gNB(s) and multi_ue (NOT 3GPP N3)
# oran-sc-ric : E2 between gNB(s) and the RIC
# metrics     : telemetry (telegraf/influx/grafana + xApp + UE export)
N2_SUBNET=10.53.1.0/24
N3_SUBNET=10.10.0.0/16
RIC_SUBNET=10.0.2.0/24
METRICS_SUBNET=172.19.1.0/24

# ── Fixed addresses ──────────────────────────────────────────────────────────
OPEN5GS_IP=10.53.1.2        # 5GC on n2 (AMF + UPF NG-U)
GNB_N2_IP=10.53.1.3         # gNB on n2
GNB_N3_IP=10.10.3.231       # gNB ZMQ tx endpoint (matches gnb_zmq.yml device_args)
GNB_METRICS_IP=172.19.1.3
GNB_RIC_IP=10.0.2.25        # gNB E2 bind addr on the RIC network
E2TERM_IP=10.0.2.10         # RIC e2term (gNB e2.addr target)
