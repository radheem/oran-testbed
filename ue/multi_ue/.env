# multi_ue: one container hosting N srsUEs, all sharing UE_HOST_IP and
# multiplexed by ZMQ port. Max NUM_UES is bounded by provisioned subscribers.
# Default single-UE for the e2e bring-up (UE #1 is boot-provisioned by the 5GC;
# add UEs 2..N with scripts/add_user.sh, then raise NUM_UES).
NUM_UES=2

# Networking. The gNB's ZMQ rx_port already points at 10.10.4.237:2001, so keep
# UE_HOST_IP here unless you also change the gNB device_args.
GNB_IP=10.10.3.231
UE_HOST_IP=10.10.4.237
UE_BIND_IP=10.10.4.237
ZMQ_BRIDGE_IP=10.10.4.237
UE_ZMQ_MODE=bridge

# Two-cell slicing: UEs 3,4 ride a second bridge to cell-2 gNB (slice sst=2).
# UEs 1,2 stay on cell 1 (slice sst=1). Empty = single-cell mode (default here).
CELL2_UES=
GNB2_IP=10.10.3.232
GNB2_TX_PORT=2010
GNB2_RX_PORT=2011

# Per-UE netns DNS.
UE_DNS1=1.1.1.1
UE_DNS2=8.8.8.8

# Set to true to keep the container idle (run start_all.sh manually).
DEBUG_MODE=false
